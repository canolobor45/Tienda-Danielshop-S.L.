<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Danielshop-S.L. - Gestión</title>
    <link rel="stylesheet" href="style.css"> </head>
<body>
    <h1>Tienda-Danielshop-S.L. (Parte I)</h1>

    <div class="container">
        <section class="form-box">
            <h2>Añadir Producto</h2>
            <input type="text" id="prodId" placeholder="ID del Producto">
            <input type="text" id="prodNombre" placeholder="Nombre">
            <input type="number" id="prodPrecio" placeholder="Precio">
            <button onclick="crear()">Guardar</button>
        </section>

        <section class="form-box">
            <h2>Actualizar Precio (PATCH)</h2>
            <input type="text" id="patchId" placeholder="ID del Producto">
            <input type="number" id="nuevoPrecio" placeholder="Nuevo Precio">
            <button onclick="actualizar()">Aplicar Cambio</button>
        </section>
    </div>

    <div id="lista"></div>
    <script src="script.js"></script> </body>
</html>
