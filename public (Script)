async function crear() {
    const data = {
        id: document.getElementById('prodId').value,
        nombre: document.getElementById('prodNombre').value,
        precio: document.getElementById('prodPrecio').value
    };
    await fetch('/api/productos', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify(data)
    });
    alert("Producto guardado");
}

async function actualizar() {
    const id = document.getElementById('patchId').value;
    const data = { precio: document.getElementById('nuevoPrecio').value };
    
    // REQUISITO: Implementar PATCH [cite: 44, 46]
    await fetch(`/api/productos/${id}`, {
        method: 'PATCH',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify(data)
    });
    alert("Precio actualizado en Danielshop");
}
